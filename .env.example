# Supabase — create project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ImageKit — create account at https://imagekit.io → Developer Options
NEXT_PUBLIC_IMAGEKIT_URL=https://ik.imagekit.io/your-id
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_xxx
IMAGEKIT_PRIVATE_KEY=private_xxx

# Resend — create API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxx
INQUIRY_NOTIFICATION_EMAIL=owner@example.com
INQUIRY_FROM_EMAIL=inquiries@vigneshwaranovelties.com

# Owner contact — used for click-to-chat WhatsApp deep links (no leading +)
NEXT_PUBLIC_WHATSAPP_NUMBER=919866777053
NEXT_PUBLIC_OWNER_PHONE=+919866777053
NEXT_PUBLIC_OWNER_EMAIL=hivexlabsx@gmail.com

# Site
NEXT_PUBLIC_SITE_URL=https://vigneshwaranovelties.com
NEXT_PUBLIC_SITE_NAME="Vigneshwara Novelties"
