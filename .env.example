# Supabase — create project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ImageKit — image CDN/transforms. Only the URL is needed (we transform via the
# public URL in lib/imagekit.ts; uploads go to Supabase Storage, not ImageKit).
NEXT_PUBLIC_IMAGEKIT_URL=https://ik.imagekit.io/your-id

# Brevo — free 300 emails/day, plain HTTPS API (no domain needed).
# Setup: sign in at https://app.brevo.com → Senders & IPs → Senders → add + verify your gmail.
# Then SMTP & API → API Keys tab → Generate (key starts with xkeysib-, NOT xsmtpsib-).
BREVO_API_KEY=xkeysib-xxx
BREVO_FROM_EMAIL=verified-sender@example.com
BREVO_FROM_NAME="Vigneshwara Novelties"
INQUIRY_NOTIFICATION_EMAIL=owner@example.com

# Owner contact — used for click-to-chat WhatsApp deep links (no leading +)
NEXT_PUBLIC_WHATSAPP_NUMBER=919866777053
NEXT_PUBLIC_OWNER_PHONE=+919866777053
NEXT_PUBLIC_OWNER_EMAIL=hivexlabsx@gmail.com

# Site
NEXT_PUBLIC_SITE_URL=https://vigneshwaranovelties.com
NEXT_PUBLIC_SITE_NAME="Vigneshwara Novelties"

# Web Push (VAPID) — admin gets a push alert on each new inquiry.
# Generate keys with: npx tsx scripts/generate-vapid-keys.ts
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID subject (mailto: URI). Falls back to INQUIRY_NOTIFICATION_EMAIL, then admin@vigneshwaranovelties.com
VAPID_SUBJECT=

# ─────────────────────────────────────────────────────────
# AI product image generation (AWS Bedrock — Stability Control Structure)
# Leave AWS keys blank to run in DEMO MODE — the admin "AI Studio" works with
# placeholder images so you can test the review/approval flow at zero cost.
# ─────────────────────────────────────────────────────────
AI_GENERATION_ENABLED=true       # set "false" to hide the AI Studio panel entirely
AI_IMAGES_PER_PRODUCT=5          # how many variants to generate per product (1-8)
AI_MAX_RETRIES=2                 # retries per image on transient API errors
AI_STORAGE_PREFIX=ai             # folder prefix inside the product-images bucket

# AWS Bedrock — IAM user with bedrock:InvokeModel; enable model access first in
# the Bedrock console. The current shot prompts are sent to Stability Control
# Structure, which re-renders each scene guided by the uploaded photo.
# The model is a cross-region inference profile, so the id MUST start with "us.".
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=             # only if using temporary/SSO credentials
BEDROCK_IMAGE_MODEL_ID=us.stability.stable-image-control-structure-v1:0
BEDROCK_CONTROL_STRENGTH=0.8     # 0..1 — higher stays closer to the uploaded piece
