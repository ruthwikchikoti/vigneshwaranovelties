# Supabase — create project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ImageKit — image CDN/transforms. Only the URL is needed (we transform via the
# public URL in lib/imagekit.ts; uploads go to Supabase Storage, not ImageKit).
NEXT_PUBLIC_IMAGEKIT_URL=https://ik.imagekit.io/your-id

# Brevo — free 300 emails/day, plain HTTPS API (no domain needed).
# Setup: sign in at https://app.brevo.com → Senders & IPs → Senders → add + verify your gmail.
# Then SMTP & API → API Keys tab → Generate (key starts with xkeysib-, NOT xsmtpsib-).
BREVO_API_KEY=xkeysib-xxx
BREVO_FROM_EMAIL=verified-sender@example.com
BREVO_FROM_NAME="Vigneshwara Novelties"
INQUIRY_NOTIFICATION_EMAIL=owner@example.com

# Owner contact — used for click-to-chat WhatsApp deep links (no leading +)
NEXT_PUBLIC_WHATSAPP_NUMBER=919866777053
NEXT_PUBLIC_OWNER_PHONE=+919866777053
NEXT_PUBLIC_OWNER_EMAIL=hivexlabsx@gmail.com

# Site
NEXT_PUBLIC_SITE_URL=https://vigneshwaranovelties.com
NEXT_PUBLIC_SITE_NAME="Vigneshwara Novelties"

# ─────────────────────────────────────────────────────────
# AI product image generation (OpenAI gpt-image-1)
# Leave OPENAI_API_KEY blank to run in DEMO MODE — the admin "AI Studio" works
# with placeholder images so you can test the review/approval flow at zero cost.
# ─────────────────────────────────────────────────────────
AI_GENERATION_ENABLED=true       # set "false" to hide the AI Studio panel entirely
AI_IMAGES_PER_PRODUCT=5          # how many variants to generate per product (1-8)
AI_MAX_RETRIES=2                 # retries per image on transient API errors
AI_STORAGE_PREFIX=ai             # folder prefix inside the product-images bucket

# OpenAI image editing (gpt-image-1) — re-shoots the uploaded photo into studio /
# lifestyle / on-model looks while keeping the exact piece. Get a key at
# https://platform.openai.com/api-keys . Billed per image; OPENAI_IMAGE_QUALITY
# is the main cost knob (low < medium < high). The on-model shot only generates
# when AI_IMAGES_PER_PRODUCT=6 (it is shot #6, flagged experimental).
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024      # 1024x1024 | 1024x1536 | 1536x1024 | auto
OPENAI_IMAGE_QUALITY=medium      # default tier; per-shot overrides in presets.ts win
OPENAI_INPUT_FIDELITY=high       # "high" keeps the exact piece (best for jewellery)
OPENAI_OUTPUT_COMPRESSION=80     # WebP compression 1-100 (smaller files, faster site)
