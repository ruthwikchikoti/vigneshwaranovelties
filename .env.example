# Supabase — create project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ImageKit — create account at https://imagekit.io → Developer Options
NEXT_PUBLIC_IMAGEKIT_URL=https://ik.imagekit.io/your-id
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_xxx
IMAGEKIT_PRIVATE_KEY=private_xxx

# Brevo — free 300 emails/day, works on Cloudflare edge (HTTPS API, no domain needed).
# Setup: sign in at https://app.brevo.com → Senders & IPs → Senders → add + verify your gmail.
# Then SMTP & API → API Keys tab → Generate (key starts with xkeysib-, NOT xsmtpsib-).
BREVO_API_KEY=xkeysib-xxx
BREVO_FROM_EMAIL=verified-sender@example.com
BREVO_FROM_NAME="Vigneshwara Novelties"
INQUIRY_NOTIFICATION_EMAIL=owner@example.com

# Owner contact — used for click-to-chat WhatsApp deep links (no leading +)
NEXT_PUBLIC_WHATSAPP_NUMBER=919866777053
NEXT_PUBLIC_OWNER_PHONE=+919866777053
NEXT_PUBLIC_OWNER_EMAIL=hivexlabsx@gmail.com

# Site
NEXT_PUBLIC_SITE_URL=https://vigneshwaranovelties.com
NEXT_PUBLIC_SITE_NAME="Vigneshwara Novelties"

# ─────────────────────────────────────────────────────────
# AI product image generation (AWS Bedrock)
# Leave AWS keys blank to run in DEMO MODE — the admin "AI Studio" works with
# placeholder images so you can test the review/approval flow at zero cost.
# ─────────────────────────────────────────────────────────
AI_GENERATION_ENABLED=true       # set "false" to hide the AI Studio panel entirely
AI_IMAGES_PER_PRODUCT=5          # how many variants to generate per product (1-8)
AI_MAX_RETRIES=2                 # retries per image on transient Bedrock errors
AI_STORAGE_PREFIX=ai             # folder prefix inside the product-images bucket

# AWS Bedrock — create an IAM user with bedrock:InvokeModel, then paste keys here.
# Enable model access in the Bedrock console first (see README / CLAUDE.md).
# Pipeline: Bedrock Stability "Remove Background" isolates the exact piece, then
# we composite it onto clean studio backdrops locally (sharp). The model is a
# cross-region inference profile, so the id MUST start with "us.".
# (Image models are not in ap-south-1/Mumbai; us-west-2 hosts this one.)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=             # only if using temporary/SSO credentials
BEDROCK_REMOVE_BG_MODEL_ID=us.stability.stable-image-remove-background-v1:0
# Styled "scene" shots (lifestyle/angle) follow the piece's structure at high
# strength with a fixed seed (deterministic). Also a us. inference profile.
BEDROCK_CONTROL_MODEL_ID=us.stability.stable-image-control-structure-v1:0
