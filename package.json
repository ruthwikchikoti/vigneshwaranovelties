    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "motion": "^11.13.1",
    "next": "^15.1.3",
    "next-intl": "^3.26.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.7",
