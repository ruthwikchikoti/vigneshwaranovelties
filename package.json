  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "admin:create": "tsx scripts/create-admin.ts",
    "storage:setup": "tsx scripts/setup-storage.ts",
